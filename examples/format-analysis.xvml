@spec 1
@file "examples/format-analysis.xvml"
@meta "description" "XVML vs HTML vs Markdown — head-to-head analysis against real websites"
@page "XVML vs HTML vs Markdown" light
@nav Home=readme.xvml | Dashboard=dashboard.xvml | Demo=dynamic-demo.xvml

@card
  @title "XVML vs HTML vs Markdown" xl
  @subtitle "Head-to-head analysis against two real production websites"
  @text "Benchmarked 2026-06-13 against live fetches of news.ycombinator.com and github.com/login. Each page was recreated in all three formats with identical real content, then measured for source size, capability coverage, and output quality. This report itself is written in XVML." muted
@end

@card "Executive summary"
  @stats
    @stat "90%" "Confidence: app-style pages" up
    @stat "85%" "Confidence: AI generation" up
    @stat "55%" "Confidence: long-form prose" neutral
    @stat "25%" "Confidence: custom design" down
  @end
  @text "XVML is a high-confidence choice inside its niche — forms, dashboards, settings pages, docs portals, internal tools, and AI-generated UI — where it is 2–6× more compact than hand-written HTML and does things Markdown structurally cannot. It is not a replacement for HTML when pixel-perfect custom design is the goal, nor for Markdown when the content is long-form prose."
@end

@card "Methodology"
  @list ordered
    @item "Fetched two live production pages: the Hacker News front page (content/list archetype) and the GitHub login page (app/form archetype)"
    @item "Measured the real pages: raw HTML bytes, tag counts, external asset dependencies"
    @item "Recreated each page in XVML, hand-written HTML (fair: minimal, semantic, inline CSS), and Markdown — using the real fetched content (actual story titles, points, authors)"
    @item "Rendered the XVML versions with xvml render; all six artifacts measured with wc"
    @item "Counted LLM tokens for every artifact with gpt-tokenizer (cl100k_base) — a standard, reproducible proxy; Claude's tokenizer differs slightly but preserves the ratios"
    @item "Scored capability coverage and per-use-case confidence from the measured evidence"
  @end
@end

@card "What the real pages measure"
  @table striped
    @row "Metric" "news.ycombinator.com" "github.com/login"
    @row "Raw HTML size" "34,786 bytes" "45,695 bytes"
    @row "HTML tags" "~730 (226 <a>, 240 <span>, 159 <td>)" "495"
    @row "External stylesheets" "1 (news.css)" "28"
    @row "External scripts" "1 (hn.js)" "52"
    @row "Self-contained?" "No" "No"
    @row "Form inputs" "1" "16"
  @end
  @text "Both production pages depend on external assets — they break offline and are not reproducible from a single file. Every figure below for XVML output is a single fully self-contained file." muted
@end

@divider "Scenario A — Hacker News front page (content/list archetype)"

@card "A1 · XVML — 963 bytes, 23 lines"
  @text "Data-driven: the six stories live in @data state, the row template is an @each. Changing the stories means editing JSON, not markup — or fetching it live with @data src=/stories.json." muted
  @codeblock xvml
@spec 1
@page "Hacker News" light
@nav Hacker News | new | past | comments | ask | show | jobs | submit

@data
{
  "stories": [
    { "rank": 1, "title": "CRISPR tech selectively shreds cancer cells…", "points": 323, "by": "signa11" },
    { "rank": 2, "title": "I Am Not a Reverse Centaur", "points": 47, "by": "doctorow" },
    { "rank": 3, "title": "A PDF that changes based on how its read", "points": 64, "by": "pdfgeek" }
  ]
}
# close the @data block with @-@-end (two @ signs)

@card
  @each story in stories
    @text "{story.rank}. {story.title}" bold
    @text "{story.points} points by {story.by}" muted
  @end
@end
  @@end
@end

@card "A2 · Hand-written HTML — 2,071 bytes, 52 lines"
  @text "A fair, minimal, semantic recreation with inline CSS (to match XVML's self-containment). Every story is hard-coded markup; restyling means touching CSS classes by hand." muted
  @codeblock html
<!DOCTYPE html>
<html lang="en">
<head>
<style>
  nav { background: #ff6600; padding: 0.4rem 0.6rem; }
  nav a { color: #000; text-decoration: none; margin-right: 0.7rem; }
  .story .title { font-size: 0.95rem; color: #000; }
  .story .meta { font-size: 0.75rem; color: #828282; }
  /* …18 more lines of CSS… */
</style>
</head>
<body>
<nav>
  <a class="brand" href="#">Hacker News</a>
  <a href="#">new</a><a href="#">past</a><a href="#">comments</a>
</nav>
<main>
  <div class="story">
    <div class="title">1. <a href="#">CRISPR tech selectively shreds cancer cells…</a></div>
    <div class="meta">323 points by signa11</div>
  </div>
  <!-- …repeated literally for every story… -->
</main>
</body>
</html>
  @@end
@end

@card "A3 · Markdown — 646 bytes, 16 lines"
  @text "The smallest source — Markdown's home turf is exactly this kind of linked list. But it needs an external converter plus a stylesheet to become a web page, the nav bar is just a row of links with no styling control, and there is no path to scores updating live." muted
  @codeblock md
# Hacker News

[Hacker News](#) | [new](#) | [past](#) | [comments](#) | [ask](#)

1. **[CRISPR tech selectively shreds cancer cells…](#)**
   323 points by signa11
2. **[I Am Not a Reverse Centaur](#)**
   47 points by doctorow
3. **[A PDF that changes based on how its read](#)**
   64 points by pdfgeek
  @@end
@end

@card "Scenario A — measurements"
  @table bordered
    @row "Metric" "XVML" "HTML" "Markdown"
    @row "Source size" "963 B" "2,071 B" "646 B"
    @row "Source lines" "23" "52" "16"
    @row "Rendered output" "22,335 B self-contained" "2,071 B (is the output)" "needs converter + CSS"
    @row "Styling included" "Yes — design system built in" "Hand-written per page" "None"
    @row "Data-driven rows" "Yes (@each over JSON state)" "No — literal repetition" "No"
    @row "Live updates possible" "Yes (@data src, xvml.set)" "Only with custom JS" "No"
    @row "Dark mode / responsive" "Built in" "Hand-written" "Converter-dependent"
  @end
  @text "Verdict A: Markdown wins raw brevity for pure content (646 B), but produces a document, not a page. XVML is 2.2× smaller than the equivalent HTML, carries its own design system, and is the only version where the story list is data, not markup." muted
@end

@divider "Scenario B — GitHub login page (app/form archetype)"

@card "B1 · XVML — 386 bytes, 15 lines"
  @codeblock xvml
@spec 1
@page "Sign in to GitHub" light
@card "Sign in to GitHub"
  @field email "Username or email address"
  @field password "Password" secret
  @link "Forgot password?" "#"
  @button "Sign in" primary full
  @divider "or"
  @button "Sign in with a passkey" secondary full
  @checkbox "Keep me signed in"
@end
@card
  @text "New to GitHub?" muted
  @link "Create an account" "#"
@end
  @@end
@end

@card "B2 · Hand-written HTML — 2,487 bytes, 50 lines"
  @text "More than half the file is CSS just to make the form presentable. Sixteen of the lines are the form; the rest is styling overhead XVML ships for free." muted
  @codeblock html
<style>
  .card { background: #fff; border: 1px solid #d8dee4; border-radius: 8px;
          padding: 1.25rem; width: 320px; }
  input[type="text"], input[type="password"] {
    width: 100%; padding: 0.4rem 0.6rem; border: 1px solid #d8dee4; }
  button { width: 100%; padding: 0.45rem; border-radius: 6px; }
  .primary { background: #1f883d; color: #fff; }
  /* …20 more lines of CSS… */
</style>
<div class="card">
  <h1>Sign in to GitHub</h1>
  <form>
    <label for="login">Username or email address</label>
    <input type="text" id="login" name="login" />
    <label for="password">Password</label>
    <input type="password" id="password" name="password" />
    <button type="submit" class="primary">Sign in</button>
    <div class="divider">or</div>
    <button type="button" class="secondary">Sign in with a passkey</button>
    <label class="checkbox"><input type="checkbox" /> Keep me signed in</label>
  </form>
</div>
  @@end
@end

@card "B3 · Markdown — structurally impossible"
  @alert error "Markdown has no form elements. No inputs, no buttons, no password masking, no checkboxes that submit. The closest approximation is a textual sketch."
  @codeblock md
# Sign in to GitHub

Username or email address: ____________

Password: ____________

**[ Sign in ]**

- [ ] Keep me signed in
  @@end
  @text "This renders as prose with blanks. It is not a form and can never become one without abandoning Markdown for embedded raw HTML — at which point you are writing HTML." muted
@end

@card "Scenario B — measurements"
  @table bordered
    @row "Metric" "XVML" "HTML" "Markdown"
    @row "Source size" "386 B" "2,487 B" "501 B (non-functional)"
    @row "Source lines" "15" "50" "26"
    @row "Working form controls" "Yes — 4 controls" "Yes — 4 controls" "None"
    @row "Source-to-HTML ratio" "6.4× smaller" "1×" "n/a"
    @row "Password masking" "secret keyword" "type=password + CSS" "Impossible"
    @row "Rendered output" "16,772 B self-contained" "2,487 B" "n/a"
  @end
  @text "Verdict B: this is XVML's strongest case. 6.4× less source than hand-written HTML for an identical working form, while Markdown is disqualified entirely. The real GitHub login page needs 45,695 bytes of HTML plus 28 stylesheets and 52 scripts; the XVML equivalent is one 16.7 KB file." muted
@end

@divider "Overall analysis"

@card "Token utilization (LLM cost of each format)"
  @text "Tokens are the unit of cost, latency, and context budget when an AI writes or edits a page. Measured with cl100k_base on the exact artifacts above:" muted
  @table bordered
    @row "Artifact" "XVML" "HTML" "Markdown"
    @row "HN front page — source" "323 tokens" "683 tokens" "218 tokens"
    @row "Login page — source" "120 tokens" "832 tokens" "123 tokens (non-functional)"
    @row "Rendered output (HN / login)" "7,228 / 5,556" "source is the output" "n/a"
    @row "Real production page (HN / GitHub login)" "—" "11,868 / 14,321 tokens" "—"
  @end
  @stats
    @stat "6.9×" "fewer output tokens than HTML (login)" up
    @stat "119×" "fewer than the real GitHub login page" up
    @stat "2.1×" "fewer than HTML (HN page)" up
    @stat "46×" "cheaper round-trip edits vs rendered HTML" up
  @end
  @list unordered
    @item "Generation: an LLM producing the login page emits 120 tokens of XVML vs 832 of equivalent HTML — ~7× less output means ~7× lower cost and latency per page, since output tokens are billed at a premium and stream serially"
    @item "Editing: to change a page the model must re-read it. Keeping XVML as the source of truth costs 120–323 tokens of context per page; using rendered HTML as the source costs 5,556–7,228 — a 17–46× context tax"
    @item "Markdown is token-competitive with XVML on pure content (218 vs 323) but cannot express the form scenario at any token count"
    @item "Error surface scales with output length: 120 constrained-grammar tokens validated by xvml check is a far smaller space for hallucination than 832+ tokens of free-form HTML"
  @end
  @text "This is why xvml ask works reliably at temperature 0: the model writes the short, constrained representation, and the deterministic renderer expands it into the long one." muted
@end

@card "Capability matrix"
  @table striped
    @row "Capability" "XVML" "HTML" "Markdown"
    @row "Human-readable source" "Yes" "No" "Yes"
    @row "Working forms (inputs, buttons, selects)" "Yes" "Yes" "No"
    @row "Built-in design system (dark mode, responsive)" "Yes" "No — bring your own" "No"
    @row "Self-contained single-file output" "Always" "Rarely in practice" "No (needs converter)"
    @row "Deterministic output (same input → same bytes)" "Guaranteed" "Author-dependent" "Converter-dependent"
    @row "Reactive state without a framework" "Yes (~5 KB runtime)" "Hand-written JS" "No"
    @row "Data-driven content (loops over JSON)" "Yes" "No (needs JS/templating)" "No"
    @row "Arbitrary pixel-perfect design" "No — fixed design system" "Yes" "No"
    @row "Arbitrary JS logic" "No — fixed action grammar" "Yes" "No"
    @row "Long-form prose ergonomics" "Adequate" "Poor" "Excellent"
    @row "Constrained grammar for AI generation" "Yes — spec-checkable" "No — unbounded" "Partially"
  @end
@end

@card "Confidence by use case"
  @text "Confidence that choosing XVML over the alternatives is the right call, based on the measured evidence:" muted
  @progress "Login / settings / form pages" 90 100 success
  @progress "Dashboards and internal tools" 88 100 success
  @progress "AI-generated pages (xvml ask)" 85 100 success
  @progress "Docs portals and spec pages" 80 100 success
  @progress "Reactive state UI (simple apps)" 80 100 success
  @progress "Long-form articles and blogs" 55 100 warning
  @progress "Marketing / pixel-perfect design" 25 100 error
  @text "Where the bar is low, use the other tool: Markdown for prose, raw HTML (or a framework) for unconstrained design." muted
@end

@card "Where each format honestly wins"
  @cols 3
    @section "XVML wins"
      @list check
        @item "App-style pages: 2–6× less source than HTML"
        @item "Zero styling decisions — consistent design system"
        @item "Single-file deterministic output"
        @item "Reactivity with no framework or build step"
        @item "AI generation: constrained grammar, spec-checkable, temperature 0"
      @end
    @end
    @section "HTML wins"
      @list check
        @item "Unconstrained design — any layout, any brand"
        @item "Arbitrary JavaScript logic"
        @item "Universal ecosystem and tooling"
        @item "No abstraction ceiling — full platform access"
      @end
    @end
    @section "Markdown wins"
      @list check
        @item "Long-form prose — lowest friction ever designed"
        @item "Smallest source for pure content (646 B vs 963 B)"
        @item "Ubiquitous support (GitHub, editors, chat)"
        @item "Trivially diffable and reviewable"
      @end
    @end
  @end
@end

@card "Known XVML limitations"
  @constraint "design-ceiling" "No custom CSS per element — the design system is the design. Brand-specific layouts are out of scope" must
  @constraint "logic-ceiling" "Actions are a fixed grammar (set/toggle/push/remove/fn) — arbitrary client logic requires fn: escape hatches to window functions" must
  @constraint "output-weight" "Self-containment costs bytes: every page carries the full CSS (~16 KB) even when it uses three commands" should
  @constraint "ecosystem" "One implementation, one design system, no third-party component market — maturity risk vs 30 years of HTML" should
@end

@card "Final verdict"
  @alert success "High confidence (85–90%) inside the niche: structured app-style pages, internal tools, docs portals, and AI-generated UI. The login benchmark — 386 bytes of XVML versus 2,487 bytes of hand-written HTML versus structural impossibility in Markdown — is the clearest single data point."
  @alert warning "Moderate confidence (55%) for prose-heavy content: Markdown remains the better authoring format for articles; XVML is viable when the prose needs to live inside a styled, navigable site."
  @alert error "Low confidence (25%) for pixel-perfect custom design: that is HTML's home ground and XVML does not compete there by design."
  @text "Positioning: XVML does not replace HTML or Markdown. It occupies the gap between them — pages too interactive for Markdown but too structured to justify hand-writing HTML. Within that gap, the measurements favour it consistently." muted
@end
