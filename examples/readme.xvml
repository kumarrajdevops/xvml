@spec 1
@file "examples/readme.xvml"
@meta "description" "XVML — eXpressive Visual Markup Language CLI renderer. Official documentation."

@page "@xvml/cli"
@nav Home=readme.html | Dashboard=dashboard.html | Demo=dynamic-demo.html | Settings=settings.html

@card
  @cols 2
    @section "What is XVML?"
      @title "eXpressive Visual Markup Language" lg
      @subtitle "Write plain text. Render live UI."
      @text "XVML sits between Markdown and HTML — as readable as Markdown, as structured as HTML. The CLI compiles .xvml files into fully self-contained, deterministic HTML — static or reactive." muted
      @layout inline
      @badge "v0.1.5" info
      @badge "ISC" neutral
      @badge "Node ≥ 18" neutral
    @end
    @section "Core guarantees"
      @list check
        @item "All CSS inlined — no CDN, no external fonts"
        @item "Same .xvml input always produces byte-identical HTML"
        @item "Unknown commands cause a render error, never silent fallback"
        @item "Single output file per source file — zero dependencies at runtime"
        @item "Works offline once installed"
        @item "Claude AI integration via xvml ask"
        @item "Reactive pages via @if, @each, @bind, on:click — no framework needed"
        @item "VS Code extension — syntax highlighting + live preview"
      @end
    @end
  @end
@end

@card "Install"
  @codeblock bash
npm install -g @xvml/cli
  @@end
  @alert success "After install the xvml binary is available globally in your PATH."
@end

@card "Quick start"
  @codeblock bash
# 1. Scaffold config in your project
xvml init

# 2. Render a single file → docs/login.html
xvml render login.xvml

# 3. Watch mode — re-renders on every save
xvml render login.xvml --watch

# 4. Render every .xvml file in the project at once
xvml build

# 5. Spec compliance check (glob supported)
xvml check "**/*.xvml"

# 6. Ask Claude to generate and render a page from a description
export ANTHROPIC_API_KEY=sk-ant-...
xvml ask "Incident dashboard with alerts and incident table" --out incident
  @@end
@end

@card "All commands"
  @table striped
    @row "Command" "What it does" "Output"
    @row "xvml init" "Create CLAUDE.md and .xvmlrc in current directory" "CLAUDE.md, .xvmlrc"
    @row "xvml render <file.xvml>" "Compile one file" "docs/<name>.html"
    @row "xvml render <file.xvml> --watch" "Re-render on every save" "docs/<name>.html"
    @row "xvml build" "Render all .xvml files in project" "docs/*.html"
    @row "xvml check <file|dir|glob>" "Spec compliance — exits 1 on errors, warns on missing @spec / @page" "stdout report"
    @row "xvml ask \"<task>\"" "Ask Claude to generate + render an XVML page" "examples/<slug>.xvml + docs/<slug>.html"
  @end
@end

@card "AI integration — xvml ask"
  @subtitle "Describe a page in plain English. Claude writes the XVML. The CLI renders it."
  @codeblock bash
# Set your Anthropic API key
export ANTHROPIC_API_KEY=sk-ant-...

# Generate and render in one command
xvml ask "login page with email and password"
xvml ask "team settings page with member table and invite form" --out team-settings
xvml ask "billing dashboard with usage stats and invoice history" --out billing

# Preview the XVML without saving or rendering
xvml ask "simple profile card" --print

# Use a specific Claude model
xvml ask "dashboard" --model claude-opus-4-8
  @@end
  @alert info "Temperature 0 means the same task description always generates the same XVML."
@end

@card "Dynamic pages — @if, @each, @bind, on:click"
  @subtitle "Add reactivity without a framework. A ~5 KB JS runtime is embedded only when needed."
  @codeblock xvml
@spec 1
@page "Dynamic demo" light
@persist "my-app"

@data
{ "name": "Alex", "count": 0, "todos": ["Ship it"], "user": { "active": true } }
# close @data with @@end

@card "Conditions and actions"
  @if count > 0
    @badge "positive" success
  @else
    @badge "zero" neutral
  @end
  @button "Set to 10" primary on:click=count=10
  @button "Toggle" ghost on:click=toggle:user.active
@end

@card "Editable list"
  @each todo in todos
    @bind todo "Todo" text
    @button "✕" sm ghost on:click=remove:todos:{todo__index}
  @end
  @button "Add" secondary on:click=push:todos=New
@end

@card "Two-way binding"
  @bind name "Your name" text
  @text "Hello {name}"
  @button "Members only" primary bind:disabled=!user.active
@end
  @@end
  @cols 2
    @section "Dynamic commands"
      @table compact
        @row "Command" "What it does"
        @row "@data ... @@end" "Define initial state as JSON (or @data src=/state.json to fetch)"
        @row "@persist \"key\"" "Save state to localStorage — survives reloads"
        @row "@if <cond> / @else" "Conditions: key, !key, count > 0, role == \"admin\""
        @row "@each item in collection" "Loop template — nestable, item-scoped collections work"
        @row "@bind <var> \"label\" [type]" "Two-way input: text, number, checkbox, select \"A | B\""
        @row "@var <key>" "Render state value inline — dot paths supported"
        @row "on:click=<action>" "key=value, toggle:key, push:key=value, remove:key:{i}, fn:name"
        @row "bind:<attr>=<path>" "Bind any HTML attribute to state: bind:disabled=!loggedIn"
        @row "\"Hello {name}\"" "{path} interpolation in any string argument"
      @end
    @end
    @section "Browser console API"
      @list unordered
        @item "xvml.state — view current state"
        @item "xvml.set('key', value) — update and re-render"
        @item "xvml.get('key') — read a value"
        @item "xvml.push('key', v) / xvml.removeAt('key', i) — array ops"
        @item "xvml.persist('key') — sync state to localStorage"
        @item "xvml.load(url) — overlay state from remote JSON"
      @end
    @end
  @end
@end

@card "VS Code extension"
  @subtitle "Syntax highlighting + live preview panel for .xvml files"
  @list check
    @item "Highlights all @commands, strings, {path} interpolation, on:/bind: attributes"
    @item "Open Preview renders the file side-by-side, updating as you type"
    @item "Nav links navigate between .xvml files inside the preview panel"
    @item "Preview refreshes when files change on disk — git, CLI, AI agents"
  @end
  @codeblock bash
cd packages/vscode-xvml
npm install && npm run package
code --install-extension xvml-*.vsix --force
  @@end
@end

@card "Why XVML?"
  @table bordered
    @row "Capability" "Markdown" "Raw HTML" "XVML"
    @row "Human-readable source" "Yes" "No" "Yes"
    @row "Renders interactive UI" "No" "Yes" "Yes"
    @row "No build toolchain needed" "Yes" "Yes" "Yes"
    @row "Fully self-contained output" "No" "No" "Yes"
    @row "Deterministic byte-for-byte output" "Yes" "No" "Yes"
    @row "Form elements (inputs, selects)" "No" "Yes" "Yes"
    @row "Data components (tables, stats)" "No" "Manual" "Yes"
    @row "Light / dark mode built-in" "No" "Manual" "Yes"
    @row "Mobile responsive by default" "No" "Manual" "Yes"
    @row "Reactive / dynamic layer" "No" "Yes" "Yes"
    @row "AI page generation (xvml ask)" "No" "No" "Yes"
  @end
@end

@card "Command syntax"
  @text "Every XVML command starts with @ on its own line." muted
  @codeblock xvml
@command "string-arg" keyword-arg key=value

@block-command "optional label" modifier
  @child-command "arg"
@end
  @@end
  @cols 3
    @section "Argument types"
      @list unordered
        @item "String — double quotes: \"Hello\""
        @item "Keyword — bare word: primary, dark"
        @item "Number — bare integer: 42"
        @item "Key=value — name=value or name=\"val\""
      @end
    @end
    @section "Block commands"
      @list unordered
        @item "@card ... @end"
        @item "@section ... @end"
        @item "@cols ... @end"
        @item "@stats ... @end"
        @item "@table ... @end"
        @item "@list ... @end"
        @item "@if ... @else ... @end"
        @item "@each ... @end"
        @item "@codeblock ... @@end"
        @item "@data ... @@end"
      @end
    @end
    @section "Meta directives"
      @list unordered
        @item "@spec — declare version"
        @item "@file — source path hint"
        @item "@meta — HTML meta tag"
        @item "@renderer — output flags"
        @item "@theme — CSS custom props"
        @item "@import — inline another .xvml"
      @end
    @end
  @end
@end

@card "Project rules"
  @constraint "xvml-only" "All UI pages must be written as .xvml files — never raw .html" must
  @constraint "always-render" "After creating any .xvml file, always run: xvml render <file>" must
  @constraint "docs-output" "Rendered files always go to the /docs folder" must
  @constraint "no-cdn" "No external CDN links in rendered HTML output" must
  @constraint "deterministic" "Same .xvml input must always produce byte-identical HTML output" must
  @constraint "strict-ts" "TypeScript only — strict mode, no any types" must
  @constraint "temp-zero" "Temperature 0 on all Claude API calls" must
  @constraint "api-key" "ANTHROPIC_API_KEY must be set in environment for xvml ask" must
@end

@card "Examples"
  @subtitle "Rendered HTML pages — click to open"
  @table striped
    @row "Page" "Source" "Description"
    @row "login.html" "login.xvml" "Sign-in form with fields, checkbox, OAuth button"
    @row "dashboard.html" "dashboard.xvml" "Stats, alerts, and data table"
    @row "profile.html" "profile.xvml" "User profile card with avatar and stats"
    @row "settings.html" "settings.xvml" "Settings form with sections and toggles"
    @row "noc-dashboard.html" "noc-dashboard.xvml" "Network operations center with service health"
    @row "dynamic-demo.html" "dynamic-demo.xvml" "Reactive page: conditions, actions, editable lists, persistence"
  @end
  @layout inline
  @link "login.html" "login.html" blank
  @link "dashboard.html" "dashboard.html" blank
  @link "profile.html" "profile.html" blank
  @link "settings.html" "settings.html" blank
  @link "noc-dashboard.html" "noc-dashboard.html" blank
  @link "dynamic-demo.html" "dynamic-demo.html" blank
@end

@card "Links"
  @layout inline
  @link "XVML_SPEC.md — full language reference" "XVML_SPEC.md"
  @link "npm: @xvml/cli" "https://npmjs.com/package/@xvml/cli" blank
  @link "GitHub" "https://github.com/kumarrajdevops/xvml" blank
  @link "Playground" "https://xvml-lang.dev" blank
@end
