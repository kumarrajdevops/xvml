{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["\"", "\""]
  ],
  "autoClosingPairs": [
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" }
  ],
  "surroundingPairs": [
    ["\"", "\""],
    ["{", "}"],
    ["[", "]"]
  ],
  "wordPattern": "@?[\\w.-]+"
}
