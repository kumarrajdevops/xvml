{
  "name": "@xvml/cli",
  "version": "0.1.2",
  "description": "XVML — Visual Markup Language CLI renderer",
  "type": "module",
  "bin": {
    "xvml": "dist/bin/xvml.js"
  },
  "files": [
    "dist",
    "XVML_SPEC.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && cp XVML_SPEC.md dist/ && chmod +x dist/bin/xvml.js",
    "xvml": "node --loader ts-node/esm --no-warnings bin/xvml.ts",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "xvml",
    "markdown",
    "html",
    "cli",
    "renderer"
  ],
  "author": "Kumar Raj <kumar.raj@codvo.ai>",
  "license": "ISC",
  "homepage": "https://github.com/kumarrajdevops/xvml#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kumarrajdevops/xvml.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "fs-extra": "^11.3.5"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  }
}
